set dotenv-filename := ".env.local"

# Run full CI (install, lint, format, typecheck + bundle). Mirrors backend's `ci`.
ci:
    pnpm install
    pnpm run lint
    pnpm run format
    pnpm run build

# Run the Vite dev server on http://localhost:5173
dev:
    pnpm run dev

# Expose local port 5173 via ngrok (uses NGROK_HOST from .env.local if set)
tunnel:
    ngrok http ${NGROK_HOST:+--url=$NGROK_HOST} 5173
