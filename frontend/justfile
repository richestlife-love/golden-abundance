# Run full CI (install, lint, format, typecheck + bundle). Mirrors backend's `ci`.
ci:
    pnpm install
    pnpm run lint
    pnpm run format
    pnpm run build

# Run the Vite dev server on http://localhost:5173
dev:
    pnpm run dev

# Expose local port 5173 (https) via a reserved ngrok hostname
tunnel:
    ngrok http --url=subvitalized-occupative-katelyn.ngrok-free.dev --scheme=https 5173
